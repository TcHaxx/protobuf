    <Property Name="Writer" Id="{ffa6ac61-94fe-4c33-9958-847d4e58ee49}">
      <Declaration><![CDATA[(* Writer for this message.*)
PROPERTY PUBLIC Writer : REFERENCE TO FB_MessageWriter]]></Declaration>
      <Get Name="Get" Id="{33797eee-040f-4839-87a8-0d83ac3cda88}">
