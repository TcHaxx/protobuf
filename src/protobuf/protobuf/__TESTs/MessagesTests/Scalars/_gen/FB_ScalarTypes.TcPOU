  <POU Name="FB_ScalarTypes" Id="{c8090daf-a3df-4d62-beed-66b1b7ba6f95}" SpecialFunc="None">
    <Declaration><![CDATA[(*******************************************************************************
                          protoc-gen-twincat V0.0.0.0                           
             https://github.bhs-world.com/CorrML/protoc-gen-twincat             
*******************************************************************************)
{attribute 'no_explicit_call' := 'do not call this POU directly'}
{attribute 'no-analysis'}
FUNCTION_BLOCK INTERNAL FINAL FB_ScalarTypes IMPLEMENTS I_Message
VAR
    _fbMessageParser : FB_MessageParser(ipMessage:= THIS^);
    _fbMessageWriter : FB_MessageWriter(ipMessage:= THIS^);
    _stScalarTypes : ST_ScalarTypes;
    END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="CalculateSize" Id="{d5ada9c4-7ef6-4b93-84fd-c5f2e7c38b4d}">
      <Declaration><![CDATA[{attribute 'no-analysis'}
(* Calculates the size of this message in Protocol Buffer wire format, in bytes. *)
METHOD CalculateSize : UDINT
VAR
    nSize : UDINT;
    nRepeatedFieldSize : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// double double_value = 1;
nSize := nSize + 1 + F_ComputeDoubleSize(fValue:= _stScalarTypes.double_value);
// float float_value = 2;
nSize := nSize + 1 + F_ComputeFloatSize(fValue:= _stScalarTypes.float_value);
// int32 int32_value = 3;
nSize := nSize + 1 + F_ComputeInt32Size(anyDint:= _stScalarTypes.int32_value);
// int32 int32_value_as_word = 30;
nSize := nSize + 2 + F_ComputeInt32Size(anyDint:= _stScalarTypes.int32_value_as_word);
// int64 int64_value = 4;
nSize := nSize + 1 + F_ComputeInt64Size(anyLint:= _stScalarTypes.int64_value);
// int64 int64_value_as_dint = 40;
nSize := nSize + 2 + F_ComputeInt64Size(anyLint:= _stScalarTypes.int64_value_as_dint);
// uint32 uint32_value = 5;
nSize := nSize + 1 + F_ComputeUint32Size(anyUdint:= _stScalarTypes.uint32_value);
// uint32 uint32_value_as_byte = 50;
nSize := nSize + 2 + F_ComputeUint32Size(anyUdint:= _stScalarTypes.uint32_value_as_byte);
// uint64 uint64_value = 6;
nSize := nSize + 1 + F_ComputeUint64Size(anyUlint:= _stScalarTypes.uint64_value);
// uint64 uint64_value_as_dword = 60;
nSize := nSize + 2 + F_ComputeUint64Size(anyUlint:= _stScalarTypes.uint64_value_as_dword);
// sint32 sint32_value = 7;
nSize := nSize + 1 + F_ComputeSint32Size(anyDint:= _stScalarTypes.sint32_value);
// sint64 sint64_value = 8;
nSize := nSize + 1 + F_ComputeSint64Size(anyLint:= _stScalarTypes.sint64_value);
// fixed32 fixed32_value = 9;
nSize := nSize + 1 + F_ComputeFixed32Size(nValue:= _stScalarTypes.fixed32_value);
// fixed64 fixed64_value = 10;
nSize := nSize + 1 + F_ComputeFixed64Size(nValue:= _stScalarTypes.fixed64_value);
// sfixed32 sfixed32_value = 11;
nSize := nSize + 1 + F_ComputeSfixed32Size(nValue:= _stScalarTypes.sfixed32_value);
// sfixed64 sfixed64_value = 12;
nSize := nSize + 1 + F_ComputeSfixed64Size(nValue:= _stScalarTypes.sfixed64_value);
// bool bool_value = 13;
nSize := nSize + 1 + F_ComputeBoolSize(bValue:= _stScalarTypes.bool_value);
// string string_value = 14;
nSize := nSize + 1 + F_ComputeStringSize(anyString:= _stScalarTypes.string_value);
// bytes bytes_value = 15;
nSize := nSize + 1 + F_ComputeBytesSize(aBytes:= _stScalarTypes.bytes_value, nCount:= _stScalarTypes.bytes_value_count);
CalculateSize := nSize;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="MergeFrom" Id="{2b762a1c-de4a-43d1-88ad-ee3a1833ce96}">
      <Declaration><![CDATA[(* Merges the data from the specified coded input stream with the current message.*)
METHOD MergeFrom : HRESULT
VAR_IN_OUT
    fbParseCtx : FB_ParseContext;
END_VAR
VAR
    nTag : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[REPEAT
MergeFrom := fbParseCtx.ReadTag(nTag=> nTag);
IF SUCCEEDED(MergeFrom) AND nTag = 0 THEN
    EXIT;
END_IF;

IF FAILED(MergeFrom) THEN
    RETURN;
END_IF

CASE nTag OF
    16#09:    // double double_value = 1;
        MergeFrom := fbParseCtx.ReadDouble(fValue=> _stScalarTypes.double_value); 
    16#15:    // float float_value = 2;
        MergeFrom := fbParseCtx.ReadFloat(fValue=> _stScalarTypes.float_value); 
    16#18:    // int32 int32_value = 3;
        MergeFrom := fbParseCtx.ReadInt32(anyDint:= _stScalarTypes.int32_value); 
    16#F0:    // int32 int32_value_as_word = 30;
        MergeFrom := fbParseCtx.ReadInt32(anyDint:= _stScalarTypes.int32_value_as_word); 
    16#20:    // int64 int64_value = 4;
        MergeFrom := fbParseCtx.ReadInt64(anyLint:= _stScalarTypes.int64_value); 
    16#140:    // int64 int64_value_as_dint = 40;
        MergeFrom := fbParseCtx.ReadInt64(anyLint:= _stScalarTypes.int64_value_as_dint); 
    16#28:    // uint32 uint32_value = 5;
        MergeFrom := fbParseCtx.ReadUint32(anyUdint:= _stScalarTypes.uint32_value); 
    16#190:    // uint32 uint32_value_as_byte = 50;
        MergeFrom := fbParseCtx.ReadUint32(anyUdint:= _stScalarTypes.uint32_value_as_byte); 
    16#30:    // uint64 uint64_value = 6;
        MergeFrom := fbParseCtx.ReadUint64(anyUlint:= _stScalarTypes.uint64_value); 
    16#1E0:    // uint64 uint64_value_as_dword = 60;
        MergeFrom := fbParseCtx.ReadUint64(anyUlint:= _stScalarTypes.uint64_value_as_dword); 
    16#38:    // sint32 sint32_value = 7;
        MergeFrom := fbParseCtx.ReadSint32(anyDint:= _stScalarTypes.sint32_value); 
    16#40:    // sint64 sint64_value = 8;
        MergeFrom := fbParseCtx.ReadSint64(anyLint:= _stScalarTypes.sint64_value); 
    16#4D:    // fixed32 fixed32_value = 9;
        MergeFrom := fbParseCtx.ReadFixed32(nValue=> _stScalarTypes.fixed32_value); 
    16#51:    // fixed64 fixed64_value = 10;
        MergeFrom := fbParseCtx.ReadFixed64(nValue=> _stScalarTypes.fixed64_value); 
    16#5D:    // sfixed32 sfixed32_value = 11;
        MergeFrom := fbParseCtx.ReadSfixed32(nValue=> _stScalarTypes.sfixed32_value); 
    16#61:    // sfixed64 sfixed64_value = 12;
        MergeFrom := fbParseCtx.ReadSfixed64(nValue=> _stScalarTypes.sfixed64_value); 
    16#68:    // bool bool_value = 13;
        MergeFrom := fbParseCtx.ReadBool(bValue=> _stScalarTypes.bool_value); 
    16#72:    // string string_value = 14;
        MergeFrom := fbParseCtx.ReadString(anyStringOut:= _stScalarTypes.string_value); 
    16#7A:    // bytes bytes_value = 15;
        MergeFrom := fbParseCtx.ReadBytes(aBytes:= _stScalarTypes.bytes_value, nCount=> _stScalarTypes.bytes_value_count); 
ELSE
    MergeFrom := fbParseCtx.SkipLastField();
END_CASE

UNTIL (FAILED(MergeFrom) OR nTag = 0)
END_REPEAT
]]></ST>
      </Implementation>
    </Method>
    <Property Name="MessageValue" Id="{0b51ec73-815d-46bc-94b2-7d504ea32214}">
