    <Method Name="WriteTo" Id="{88d35f46-975a-4636-b7cd-6b0441524ecb}">
      <Declaration><![CDATA[(* Writes the data to the given coded output stream.*)
METHOD WriteTo : HRESULT
VAR_IN_OUT
	(* Coded output stream to write the data to. *)
	fbWriteCtx	: FB_WriteContext;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// double double_value = 1;
WriteTo := fbWriteCtx.WriteTag(1, E_WireType.Fixed64);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteDouble(fValue:= _stScalarTypes.double_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// float float_value = 2;
WriteTo := fbWriteCtx.WriteTag(2, E_WireType.Fixed32);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteFloat(fValue:= _stScalarTypes.float_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// int32 int32_value = 3;
WriteTo := fbWriteCtx.WriteTag(3, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteInt32(anyDint:= _stScalarTypes.int32_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// int32 int32_value_as_word = 30;
WriteTo := fbWriteCtx.WriteTag(30, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteInt32(anyDint:= _stScalarTypes.int32_value_as_word);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// int64 int64_value = 4;
WriteTo := fbWriteCtx.WriteTag(4, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteInt64(anyLint:= _stScalarTypes.int64_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// int64 int64_value_as_dint = 40;
WriteTo := fbWriteCtx.WriteTag(40, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteInt64(anyLint:= _stScalarTypes.int64_value_as_dint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// uint32 uint32_value = 5;
WriteTo := fbWriteCtx.WriteTag(5, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteUint32(anyUdint:= _stScalarTypes.uint32_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// uint32 uint32_value_as_byte = 50;
WriteTo := fbWriteCtx.WriteTag(50, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteUint32(anyUdint:= _stScalarTypes.uint32_value_as_byte);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// uint64 uint64_value = 6;
WriteTo := fbWriteCtx.WriteTag(6, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteUint64(anyUlint:= _stScalarTypes.uint64_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// uint64 uint64_value_as_dword = 60;
WriteTo := fbWriteCtx.WriteTag(60, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteUint64(anyUlint:= _stScalarTypes.uint64_value_as_dword);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// sint32 sint32_value = 7;
WriteTo := fbWriteCtx.WriteTag(7, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteSint32(anyDint:= _stScalarTypes.sint32_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// sint64 sint64_value = 8;
WriteTo := fbWriteCtx.WriteTag(8, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteSint64(anyLint:= _stScalarTypes.sint64_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// fixed32 fixed32_value = 9;
WriteTo := fbWriteCtx.WriteTag(9, E_WireType.Fixed32);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteFixed32(nValue:= _stScalarTypes.fixed32_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// fixed64 fixed64_value = 10;
WriteTo := fbWriteCtx.WriteTag(10, E_WireType.Fixed64);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteFixed64(nValue:= _stScalarTypes.fixed64_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// sfixed32 sfixed32_value = 11;
WriteTo := fbWriteCtx.WriteTag(11, E_WireType.Fixed32);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteSfixed32(nValue:= _stScalarTypes.sfixed32_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// sfixed64 sfixed64_value = 12;
WriteTo := fbWriteCtx.WriteTag(12, E_WireType.Fixed64);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteSfixed64(nValue:= _stScalarTypes.sfixed64_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// bool bool_value = 13;
WriteTo := fbWriteCtx.WriteTag(13, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteBool(bValue:= _stScalarTypes.bool_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// string string_value = 14;
WriteTo := fbWriteCtx.WriteTag(14, E_WireType.LengthDelimited);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteString(sStringToWrite:= _stScalarTypes.string_value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// bytes bytes_value = 15;
WriteTo := fbWriteCtx.WriteTag(15, E_WireType.LengthDelimited);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteBytes(aBytes:= _stScalarTypes.bytes_value, nCount:= _stScalarTypes.bytes_value_count);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
]]></ST>
      </Implementation>
