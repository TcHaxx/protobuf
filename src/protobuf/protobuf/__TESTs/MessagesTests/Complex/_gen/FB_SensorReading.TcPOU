    <Property Name="SensorReading" Id="{5570caf3-97b6-4dd3-8aa0-5830a5793c51}">
      <Declaration><![CDATA[PROPERTY PUBLIC SensorReading : ST_SensorReading]]></Declaration>
      <Get Name="Get" Id="{73e7b944-4c88-4bce-9b48-fc11bf439f62}">
        <Declaration><![CDATA[VAR
