    <Property Name="Writer" Id="{c17fa6bb-0e02-4645-8f1f-076b72b11a87}">
      <Declaration><![CDATA[(* Writer for this message.*)
PROPERTY PUBLIC Writer : REFERENCE TO FB_MessageWriter]]></Declaration>
      <Get Name="Get" Id="{46167c34-4091-422d-bbc8-2094b564074f}">
