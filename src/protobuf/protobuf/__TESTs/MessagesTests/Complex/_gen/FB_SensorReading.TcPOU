  <POU Name="FB_SensorReading" Id="{d499b10e-6126-4ead-8590-7765da998266}" SpecialFunc="None">
    <Declaration><![CDATA[(*******************************************************************************
                          protoc-gen-twincat V0.0.0.0                           
                  https://github.com/TcHaxx/protoc-gen-twincat                  
*******************************************************************************)
{attribute 'no_explicit_call' := 'do not call this POU directly'}
{attribute 'no-analysis'}
FUNCTION_BLOCK INTERNAL FINAL FB_SensorReading IMPLEMENTS I_Message
VAR
    _fbMessageParser : FB_MessageParser(ipMessage:= THIS^);
    _fbMessageWriter : FB_MessageWriter(ipMessage:= THIS^);
    _stSensorReading : ST_SensorReading;
    END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="CalculateSize" Id="{23187a90-1444-48c5-ac44-5bb96d90e9d7}">
      <Declaration><![CDATA[{attribute 'no-analysis'}
(* Calculates the size of this message in Protocol Buffer wire format, in bytes. *)
METHOD CalculateSize : UDINT
VAR
    nSize : UDINT;
    nRepeatedFieldSize : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// double value = 1;
nSize := nSize + 1 + F_ComputeDoubleSize(fValue:= _stSensorReading.value);
// float precision = 2;
nSize := nSize + 1 + F_ComputeFloatSize(fValue:= _stSensorReading.precision);
// int64 timestamp = 3;
nSize := nSize + 1 + F_ComputeInt64Size(anyLint:= _stSensorReading.timestamp);
CalculateSize := nSize;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="MergeFrom" Id="{a410a047-6865-47a9-8c0b-be187e997517}">
      <Declaration><![CDATA[(* Merges the data from the specified coded input stream with the current message.*)
{attribute 'no-analysis'}
METHOD MergeFrom : HRESULT
VAR_IN_OUT
    fbParseCtx : FB_ParseContext;
END_VAR
VAR
    nTag : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[REPEAT
MergeFrom := fbParseCtx.ReadTag(nTag=> nTag);
IF SUCCEEDED(MergeFrom) AND nTag = 0 THEN
    EXIT;
END_IF;

IF FAILED(MergeFrom) THEN
    RETURN;
END_IF

CASE nTag OF
    16#09:    // double value = 1;
        MergeFrom := fbParseCtx.ReadDouble(fValue=> _stSensorReading.value); 
    16#15:    // float precision = 2;
        MergeFrom := fbParseCtx.ReadFloat(fValue=> _stSensorReading.precision); 
    16#18:    // int64 timestamp = 3;
        MergeFrom := fbParseCtx.ReadInt64(anyLint:= _stSensorReading.timestamp); 
ELSE
    MergeFrom := fbParseCtx.SkipLastField();
END_CASE

UNTIL (FAILED(MergeFrom) OR nTag = 0)
END_REPEAT
]]></ST>
      </Implementation>
    </Method>
