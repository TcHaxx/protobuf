    <Method Name="WriteTo" Id="{f79c6343-a23f-4679-a15e-ec21e93b75ba}">
      <Declaration><![CDATA[(* Writes the data to the given coded output stream.*)
{attribute 'no-analysis'}
METHOD WriteTo : HRESULT
VAR_IN_OUT
	(* Coded output stream to write the data to. *)
	fbWriteCtx	: FB_WriteContext;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// double value = 1;
WriteTo := fbWriteCtx.WriteTag(1, E_WireType.Fixed64);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteDouble(fValue:= _stSensorReading.value);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// float precision = 2;
WriteTo := fbWriteCtx.WriteTag(2, E_WireType.Fixed32);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteFloat(fValue:= _stSensorReading.precision);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
// int64 timestamp = 3;
WriteTo := fbWriteCtx.WriteTag(3, E_WireType.Varint);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
WriteTo := fbWriteCtx.WriteInt64(anyLint:= _stSensorReading.timestamp);
IF FAILED(WriteTo) THEN
    RETURN;
END_IF
]]></ST>
      </Implementation>
